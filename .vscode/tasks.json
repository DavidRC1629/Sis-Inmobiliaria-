{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend",
      "type": "shell",
      "command": "mvn spring-boot:run",
      "options": {
        "cwd": "${workspaceFolder}\\backend"
      },
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [
        {
          "owner": "spring-boot",
          "pattern": {
            "regexp": "^.*$"
          },
          "background": {
            "beginsPattern": "^.*Starting.*$",
            "endsPattern": "^.*Started .* in .* seconds.*$"
          }
        }
      ]
    },
    {
      "label": "Restart Backend",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\restart_backend.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "start-frontend-if-confirmed",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "\$resp = Read-Host '¿Iniciar frontend ahora? (S/N)'; if ($resp -match '^[sS]') { Set-Location -Path '${workspaceFolder}\\frontsisarovi'; npm install; npx ng serve --open } else { Write-Host 'Frontend no iniciado.' }"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Start Fullstack (ask)",
      "dependsOn": ["backend", "start-frontend-if-confirmed"],
      "runOptions": {
        "runOn": "default"
      }
    }
  ]
}
